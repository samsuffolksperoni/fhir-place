# LaunchDarkly client-side ID for the apps/demo SPA.
#
# Get this from the LaunchDarkly dashboard:
#   https://app.launchdarkly.com/projects/<projectKey>/settings/environments/<envKey>/keys
#
# Use the per-environment "Client-side ID" — NOT the SDK key (server) or mobile key.
# Vite exposes any var prefixed with VITE_ to the browser bundle, so this value
# ships in the deployed JS. That is expected for client-side IDs; LaunchDarkly's
# permission model assumes they are public.
#
# In CI: read from the GH Actions repo secret LAUNCHDARKLY_CLIENT_SIDE_ID and
# expose at build time, e.g.:
#   - run: pnpm build
#     env:
#       VITE_LAUNCHDARKLY_CLIENT_SIDE_ID: ${{ secrets.LAUNCHDARKLY_CLIENT_SIDE_ID }}
#
# Locally: copy this file to apps/demo/.env.local (gitignored) and fill in
# the value, or export VITE_LAUNCHDARKLY_CLIENT_SIDE_ID before `pnpm dev`.
#
# Leave unset and the demo will boot with feature flags disabled — useFlags()
# returns {} and any `flag ?? false` check defaults to off.
VITE_LAUNCHDARKLY_CLIENT_SIDE_ID=
