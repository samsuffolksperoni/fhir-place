{
  "name": "@fhir-place/react-fhir",
  "version": "0.0.0",
  "description": "Spec-driven React components for FHIR (R4) built on the plain REST API.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samsuffolksperoni/fhir-place.git",
    "directory": "packages/react-fhir"
  },
  "homepage": "https://github.com/samsuffolksperoni/fhir-place#readme",
  "bugs": "https://github.com/samsuffolksperoni/fhir-place/issues",
  "keywords": [
    "fhir",
    "fhir-r4",
    "hl7",
    "react",
    "healthcare",
    "ehr",
    "smart-on-fhir",
    "spec-driven"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    },
    "./structure": {
      "types": "./dist/structure/index.d.ts",
      "import": "./dist/structure/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./layout-hints": {
      "types": "./dist/layout-hints/index.d.ts",
      "import": "./dist/layout-hints/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "prepare": "tsc -p tsconfig.build.json",
    "sync:valuesets": "node --experimental-strip-types scripts/sync-bundled-valuesets.ts",
    "sync:sds": "node --experimental-strip-types scripts/sync-bundled-structuredefinitions.ts",
    "sync:csys": "node --experimental-strip-types scripts/sync-bundled-codesystems.ts"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "dompurify": "^3.2.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.62.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/dompurify": "^3.0.5",
    "@types/fhir": "^0.0.41",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^10.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^25.0.1",
    "msw": "^2.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^2.1.8"
  }
}
