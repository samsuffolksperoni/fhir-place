{
  "name": "@fhir-place/demo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @fhir-place/react-fhir sync:sds && pnpm --filter @fhir-place/react-fhir sync:csys && pnpm --filter @fhir-place/react-fhir build",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "e2e": "playwright test",
    "e2e:screenshot": "playwright test --project=screenshots",
    "e2e:live": "playwright test --config=playwright.live.config.ts",
    "agent:run": "tsx e2e-agent/runner.ts",
    "agent:typecheck": "tsc --noEmit -p e2e-agent/tsconfig.json",
    "sync:fhir-spec": "node --experimental-strip-types scripts/sync-fhir-r4-sds.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "@fhir-place/react-fhir": "workspace:*",
    "@sentry/react": "^10.51.0",
    "@tanstack/react-query": "^5.62.0",
    "cql-exec-fhir": "^2.1.6",
    "cql-execution": "^3.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.0.0"
  },
  "optionalDependencies": {
    "msw": "^2.7.0"
  },
  "devDependencies": {
    "@playwright/test": "1.56.1",
    "@sentry/vite-plugin": "^5.2.1",
    "@types/fhir": "^0.0.41",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}