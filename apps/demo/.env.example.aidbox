# apps/demo — Aidbox dev (docker self-host) preset
#
# Usage:
#   cp apps/demo/.env.example.aidbox apps/demo/.env.local
#   # start Aidbox via the official docker-compose, then:
#   pnpm --filter @fhir-place/demo dev
#
# See apps/demo/docs/interop-matrix.md § "Backend 3 — Aidbox" for the
# license + docker-compose walkthrough.

# Disable the in-browser MSW mock so requests hit the local Aidbox.
VITE_USE_MOCK=false

# Aidbox FHIR endpoint. The trailing /fhir matters — the bare host returns
# Aidbox-format JSON which FetchFhirClient will not parse.
VITE_FHIR_BASE_URL=http://localhost:8080/fhir

# Optional: bearer token or basic-auth equivalent. The Aidbox dev image
# ships with `root:secret` basic auth; for `Authorization: Basic` set this
# to the base64 of `root:secret` and prefix with `Basic ` when wiring
# `getHeaders` in src/main.tsx (see the Medplum preset for the pattern).
VITE_FHIR_BEARER_TOKEN=
