# apps/demo — Medplum public sandbox preset
#
# Usage:
#   cp apps/demo/.env.example.medplum apps/demo/.env.local
#   # paste a bearer token below, then:
#   pnpm --filter @fhir-place/demo dev
#
# See apps/demo/docs/interop-matrix.md for the full setup walkthrough.

# Disable the in-browser MSW mock so requests hit the real Medplum API.
VITE_USE_MOCK=false

# Medplum public R4 endpoint. Pin to /R4/, not /R4B/.
VITE_FHIR_BASE_URL=https://api.medplum.com/fhir/R4/

# Bearer token from the OAuth2 client-credentials flow (see interop-matrix.md
# § "Backend 2 — Medplum"). Required for any read; Medplum is project-scoped.
# Wire this through `FetchFhirClient.getHeaders` in src/main.tsx — the demo
# does not consume it by default to avoid baking a static token into the
# GitHub Pages build.
VITE_FHIR_BEARER_TOKEN=
