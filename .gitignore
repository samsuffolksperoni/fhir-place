# react-fhir local FHIR spec source bundle (drop the published profiles JSON
# files here; sync-bundled-structuredefinitions.ts reads from this path)
packages/react-fhir/fhir_spec/

# react-fhir bundled per-type StructureDefinitions — committed when present.
# Run `pnpm --filter @fhir-place/react-fhir sync:sds` to (re)generate from
# the local FHIR R4 spec cache, then commit the results. The build falls back
# to the empty-loaders stub (index.generated.ts) if they are absent.

# fhir-r4 spec sync cache (zip + extracted bundle); the generated per-type
# JSON files under apps/demo/public/fhir-r4/ ARE committed.
apps/demo/scripts/cache/

# Claude editor metadata (ignore everything except shared subagent definitions,
# the session-start hook, and project settings)
.claude/*
!.claude/agents/
!.claude/hooks/
!.claude/settings.json
