# react-fhir cached spec artifacts
packages/react-fhir/scripts/cache/r4-spec/*.zip
packages/react-fhir/scripts/cache/r4-spec/expansions.json
packages/react-fhir/scripts/cache/r4-spec/profiles-resources.json
packages/react-fhir/scripts/cache/r4-spec/profiles-types.json

# react-fhir local FHIR spec source bundle (drop the published profiles JSON
# files here; sync-bundled-structuredefinitions.ts reads from this path)
packages/react-fhir/fhir_spec/

# react-fhir bundled per-type StructureDefinitions, regenerated by
# `pnpm --filter @fhir-place/react-fhir sync:sds`.
# The per-type {Type}.generated.ts modules are heavy and locally generated;
# index.generated.ts is committed as an empty stub so `tsc` always resolves
# the import — the sync script overwrites it.
packages/react-fhir/src/structure/core/sd/*.generated.ts
!packages/react-fhir/src/structure/core/sd/index.generated.ts

# fhir-r4 spec sync cache (zip + extracted bundle); the generated per-type
# JSON files under apps/demo/public/fhir-r4/ ARE committed.
apps/demo/scripts/cache/

# Claude editor metadata
.claude/
